digraph "CFG_if_else_demo" {
  rankdir=TB;
  "entry" [label="entry\n(1 inst, 2 exit(s))", shape=box, style=filled, fillcolor=lightgreen];
  "then" [label="then\n(2 inst, 1 exit(s))", shape=box, style=filled, fillcolor=white];
  "else" [label="else\n(2 inst, 1 exit(s))", shape=box, style=filled, fillcolor=white];
  "end" [label="end\n(1 inst, 0 exit(s))", shape=box, style=filled, fillcolor=lightcoral];
  "entry" -> "then" [style=dashed, color=blue, label="true"];
  "entry" -> "else" [style=dashed, color=blue, label="false"];
  "then" -> "end" [style=solid, color=red];
  "else" -> "end" [style=solid, color=red];
}